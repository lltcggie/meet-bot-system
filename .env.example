# docker compose が読み込む環境変数のサンプル。
# このファイルを `.env` にコピーして値を埋めてください。
#
# SERVICE_ACCOUNT_JSON は改行を含まない 1 行の JSON 文字列にする必要があります。
# PowerShell での生成例:
#   (Get-Content .\service_account.json -Raw | ConvertFrom-Json | ConvertTo-Json -Compress)

# === 両サービス共通 ===
SERVICE_ACCOUNT_JSON=
# meet-webhook が送信し meet-bot が検証する HMAC-SHA256 共有シークレット。
# 両サービスで必ず同じ値を指定してください。
WEBHOOK_SHARED_SECRET=

# === meet-webhook ===
ADMIN_USER_EMAIL=admin@example.com
PROJECT_ID=your-gcp-project-id
PUBSUB_TOPIC_ID=meet-events-topic
PUBSUB_SUBSCRIPTION_ID=meet-events-sub
SUBSCRIPTION_TTL=86400s
RECREATE_SUBSCRIPTION=false
# コンテナ間通信のため meet-bot のサービス名を使用する
WEBHOOK_URL=http://meet-bot:8080/webhook
WEBHOOK_TIMEOUT=30

# === meet-bot ===
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxx
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxxxxxx
